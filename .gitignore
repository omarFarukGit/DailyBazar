# =========================================================
# Production Ready .gitignore
# Stack: Next.js + Express.js + PostgreSQL + TypeScript
# =========================================================

# =========================================================
# Dependencies
# =========================================================
node_modules/
.pnp
.pnp.js

# =========================================================
# Next.js
# =========================================================
.next/
out/
.vercel/

# next build logs
next-env.d.ts

# =========================================================
# Express / Node
# =========================================================
dist/
build/
coverage/

# Runtime files
pids
*.pid
*.seed
*.pid.lock

# =========================================================
# Logs
# =========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================================================
# Environment Variables (IMPORTANT)
# =========================================================
.env
.env.*
!.env.example

# =========================================================
# Database
# =========================================================

# PostgreSQL dumps
*.sql
*.dump

# SQLite (if used temporarily)
*.sqlite
*.sqlite3
*.db

# Prisma
prisma/dev.db
prisma/dev.db-journal
prisma/*.db

# =========================================================
# TypeScript
# =========================================================
*.tsbuildinfo

# =========================================================
# Cache Files
# =========================================================
.cache/
.parcel-cache/

# Turborepo
.turbo/

# ESLint
.eslintcache

# Stylelint
.stylelintcache

# =========================================================
# Testing
# =========================================================
coverage/
.nyc_output/

# Playwright
playwright-report/
test-results/

# Cypress
cypress/videos/
cypress/screenshots/

# =========================================================
# Uploads / Temporary Files
# =========================================================
uploads/
tmp/
temp/

# =========================================================
# IDE / Editor
# =========================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# =========================================================
# OS Files
# =========================================================
.DS_Store
Thumbs.db

# =========================================================
# Docker
# =========================================================
.docker/

# docker volumes
postgres-data/

# =========================================================
# Package Managers
# =========================================================

# npm
package-lock.json

# yarn
yarn.lock

# pnpm
pnpm-lock.yaml

# Uncomment ONLY the package manager you use
# Recommended:
# Keep lock file in production apps

# =========================================================
# Security Files
# =========================================================
*.pem
*.key
*.crt
*.cert

# SSH Keys
id_rsa
id_rsa.pub

# =========================================================
# Misc
# =========================================================
*.tgz

# Local netlify folder
.netlify

# local history
.history/

# =========================================================
# Generated files
# =========================================================
generated/